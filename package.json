{
  "name": "novelforge",
  "version": "0.6.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "electron:dev": "set NODE_ENV=development && electron .",
    "electron:build": "next build && electron-builder",
    "db:init": "node prisma/init-db.js",
    "electron:build:win": "npm run db:init && next build && node -e \"var f=require('fs');var s='.next/static';var t='.next/standalone/.next/static';if(f.existsSync(s)){f.cpSync(s,t,{recursive:true});console.log('static copied')}\" && node -e \"var f=require('fs');var p='.next/standalone/node_modules';var d='.next/standalone-libs';if(f.existsSync(p)){try{f.rmSync(d,{recursive:true})}catch(e){}f.renameSync(p,d);console.log('nm renamed')}\" && electron-builder --win zip && node -e \"var f=require('fs');var p='.next/standalone/node_modules';var d='.next/standalone-libs';if(!f.existsSync(p)&&f.existsSync(d)){f.renameSync(d,p);console.log('nm restored')}\""
  },
  "build": {
    "appId": "com.novelforge.app",
    "productName": "NovelForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": ".next/standalone-libs",
        "to": "standalone/node_modules"
      },
      {
        "from": "electron/node-portable",
        "to": "node-portable"
      },
      {
        "from": "prisma/init-db.js",
        "to": "standalone/prisma/init-db.js"
      },
      {
        "from": "public",
        "to": "standalone/public"
      }
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "next-themes": "^0.4.6",
    "openai": "^6.36.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^7.8.0",
    "prisma-adapter-sqlite": "^1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  }
}
