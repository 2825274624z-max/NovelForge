{
  "name": "novelforge",
  "version": "0.5.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "next build && electron-builder",
    "electron:build:win": "next build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.novelforge.app",
    "productName": "NovelForge",
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone"
      },
      {
        "from": "prisma",
        "to": "prisma"
      },
      {
        "from": "public",
        "to": "public"
      }
    ],
    "win": {
      "target": [
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "public/favicon.ico",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.9",
    "@tiptap/extension-image": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "next-themes": "^0.4.6",
    "openai": "^6.36.0",
    "prisma": "^7.8.0",
    "prisma-adapter-sqlite": "^1.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
