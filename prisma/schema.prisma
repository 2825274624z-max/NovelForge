generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  type        String   @default("novel")
  genre       String   @default("")
  style       String   @default("")
  targetWords Int      @default(0)
  description String   @default("")
  worldView   String   @default("")
  writingReqs String   @default("")
  coverPrompt String   @default("")
  outline     String   @default("")
  status      String   @default("draft")

  chapters      Chapter[]
  characters    Character[]
  locations     Location[]
  organizations Organization[]
  items         Item[]
  foreshadowings Foreshadowing[]
  timelines     Timeline[]
  worldBuildings WorldBuilding[]
  aiSettings    AISettings?
  aiGenerations AIGeneration[]
  dailyLogs     DailyWritingLog[]
  volumes       Volume[]
  storyArcs     StoryArc[]
  plotThreads   PlotThread[]
  timelineEvents TimelineEvent[]
  chekhovGuns   ChekhovGun[]
  characterStates CharacterState[]
}

model Chapter {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title     String @default("")
  content   String @default("")
  status    String @default("draft")
  order     Int    @default(0)
  wordCount Int    @default(0)
  summary   String @default("")
  notes     String @default("")

  histories ChapterHistory[]
  outline   ChapterOutline?

  @@index([projectId])
}

model ChapterHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  title     String
  content   String
  wordCount Int
  version   Int
  summary   String @default("")

  @@index([chapterId])
}

model Character {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name          String
  identity      String @default("")
  personality   String @default("")
  goals         String @default("")
  relationships String @default("")
  quirks        String @default("")
  appearance    String @default("")
  backstory     String @default("")
  characterArc  String @default("")
  avatarPrompt  String @default("")
  order         Int    @default(0)

  @@index([projectId])
}

model WorldBuilding {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  content     String
  type        String @default("general")
  rules       String @default("")
  history     String @default("")
  factions    String @default("")
  limitations String @default("")
  order       Int    @default(0)

  @@index([projectId])
}

model Location {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name            String
  description     String @default("")
  type            String @default("")
  faction         String @default("")
  importantEvents String @default("")
  order           Int    @default(0)

  @@index([projectId])
}

model Organization {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String @default("")
  type        String @default("")
  goals       String @default("")
  members     String @default("")
  resources   String @default("")
  rivalries   String @default("")
  order       Int    @default(0)

  @@index([projectId])
}

model Item {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String @default("")
  type        String @default("")
  effect      String @default("")
  limitations String @default("")
  sideEffects String @default("")
  source      String @default("")
  order       Int    @default(0)

  @@index([projectId])
}

model Foreshadowing {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId        String
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title            String
  description      String  @default("")
  chapterHint      String  @default("")
  plantChapterId   String  @default("")
  resolveChapterId String  @default("")
  status           String  @default("planted")
  resolved         Boolean @default(false)
  order            Int     @default(0)

  @@index([projectId])
}

model Timeline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title             String
  content           String @default("")
  timePos           Int    @default(0)
  order             Int    @default(0)
  relatedCharacters String @default("")
  relatedChapters   String @default("")

  @@index([projectId])
}

model AISettings {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId   String  @unique
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  provider         String  @default("openai")
  model            String  @default("gpt-4o")
  baseUrl          String  @default("")
  apiKey           String  @default("")
  temperature      Float   @default(0.7)
  maxTokens        Int     @default(8192)
  topP             Float   @default(1.0)
  frequencyPenalty Float   @default(0)
  presencePenalty  Float   @default(0)
  reasoningEffort  String  @default("")

  @@index([projectId])
}

model DailyWritingLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date      String
  wordCount Int

  @@unique([projectId, date])
  @@index([projectId])
  @@index([projectId, date])
}

model AIGeneration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapterId String?

  workflow     String
  model        String
  provider     String
  prompt       String
  systemPrompt String  @default("")
  output       String
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(4096)

  @@index([projectId])
  @@index([chapterId])
}

// ─── v0.5: 记忆系统 + 分级大纲 ───

model Volume {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title     String
  order     Int
  summary   String   @default("")
  wordTarget Int?
  wordCount Int      @default(0)
  status    String   @default("planned") // planned|writing|done

  @@index([projectId])
}

model StoryArc {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String  @default("")
  arcType     String  @default("plot") // character|plot|theme
  status      String  @default("open") // open|ongoing|resolved

  @@index([projectId])
}

model PlotThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name            String
  description     String  @default("")
  priority        Int     @default(1)
  status          String  @default("open") // open|ongoing|resolved|dropped
  openedChapter   Int?
  resolvedChapter Int?
  note            String  @default("")

  @@index([projectId])
}

model CharacterState {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characterId String
  chapterNum  Int
  location    String  @default("")
  goal        String  @default("")
  emotion     String  @default("")
  relationships String @default("")
  note        String  @default("")

  @@index([projectId])
  @@index([characterId])
  @@index([chapterNum])
}

model TimelineEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  chapterNum Int
  eventDesc  String
  storyTime  String  @default("")
  characters String  @default("") // JSON array of character IDs

  @@index([projectId])
  @@index([chapterNum])
}

model ChekhovGun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId      String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  description    String
  plantedChapter Int
  payedChapter   Int?
  status         String  @default("planted") // planted|paid_off|abandoned

  @@index([projectId])
}

model ChapterOutline {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapterId String  @unique
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  summary       String @default("")
  keyEvents     String @default("[]") // JSON
  characterArcs String @default("[]") // JSON
  plotThreads   String @default("[]") // JSON
  wordTarget    Int    @default(0)
}
