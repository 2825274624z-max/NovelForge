{
  "$schema": "此文件为 NovelForge 用户配置文件示例。复制为 novelforge.config.json 后修改。",

  "ai": {
    "defaultProvider": "deepseek",
    "providers": {
      "openai": {
        "model": "gpt-4o",
        "baseUrl": "https://api.openai.com/v1",
        "maxTokens": 8192,
        "temperature": 0.7,
        "topP": 1.0,
        "frequencyPenalty": 0,
        "presencePenalty": 0
      },
      "deepseek": {
        "model": "deepseek-v4-flash",
        "baseUrl": "https://api.deepseek.com/v1",
        "maxTokens": 8192,
        "temperature": 0.7,
        "topP": 0.9,
        "reasoningEffort": ""
      },
      "anthropic": {
        "model": "claude-sonnet-4-5",
        "baseUrl": "https://api.anthropic.com/v1",
        "maxTokens": 8192,
        "temperature": 0.7
      },
      "gemini": {
        "model": "gemini-2.5-flash",
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta",
        "maxTokens": 8192,
        "temperature": 0.7
      },
      "openrouter": {
        "model": "anthropic/claude-sonnet-4-5",
        "baseUrl": "https://openrouter.ai/api/v1",
        "maxTokens": 8192,
        "temperature": 0.7
      },
      "ollama": {
        "model": "llama3.2",
        "baseUrl": "http://localhost:11434/v1",
        "maxTokens": 4096,
        "temperature": 0.7
      }
    }
  },

  "editor": {
    "fontSize": 16,
    "lineHeight": 1.9,
    "autoSaveIntervalMs": 2000,
    "maxPauseChars": 500
  },

  "ui": {
    "defaultTheme": "dark",
    "sidebarWidth": 220,
    "aiPanelDefaultOpen": true
  }
}
